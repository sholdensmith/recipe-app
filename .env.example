# Required: Anthropic API key for AI recipe parsing and meal suggestions
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Recommended for deployed instances: shared family password.
# When set, every page requires signing in at /login. Leave unset to disable
# auth (e.g. for local development).
# SITE_PASSWORD=

# Optional: set to use Vercel Postgres instead of the local SQLite database
# POSTGRES_URL=
